{
  "input": {
    "type": "object",
    "properties": {
      "primaryHue": {
        "type": "string",
        "description": "Primary brand hue (sky, violet, rose, amber, emerald, slate, neutral)",
        "enum": ["sky", "violet", "rose", "amber", "emerald", "slate", "neutral"],
        "default": "sky"
      },
      "neutralHue": {
        "type": "string",
        "description": "Neutral hue for grayscale palette (slate or neutral)",
        "enum": ["slate", "neutral"],
        "default": "slate"
      }
    },
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "light": {
        "type": "object",
        "description": "Light theme spec"
      },
      "dark": {
        "type": "object",
        "description": "Dark theme spec"
      },
      "availableHues": {
        "type": "array",
        "description": "List of available hue names"
      }
    }
  }
}
