{
  "input": {
    "type": "object",
    "properties": {
      "section": {
        "type": "object",
        "description": "Section object with type and component-specific properties"
      },
      "options": {
        "type": "object",
        "properties": {
          "minify": {
            "type": "boolean",
            "description": "Minify HTML output",
            "default": false
          },
          "includeComments": {
            "type": "boolean",
            "description": "Include HTML comments",
            "default": true
          },
          "tailwindCDN": {
            "type": "boolean",
            "description": "Include Tailwind CSS CDN",
            "default": true
          },
          "indentSize": {
            "type": "number",
            "description": "Number of spaces for indentation",
            "default": 2
          }
        }
      }
    },
    "required": ["section"]
  },
  "output": {
    "type": "object",
    "properties": {
      "html": {
        "type": "string",
        "description": "Generated HTML document"
      },
      "error": {
        "type": "string",
        "description": "Error message if rendering failed"
      }
    }
  }
}