{
  "name": "@jared-goguen/gutenberg",
  "version": "0.1.2",
  "type": "module",
  "description": "Dynamic page builder and edit mode framework for Cloudflare Pages",
  "main": "./dist/index-lib.js",
  "types": "./dist/index-lib.d.ts",
  "license": "UNLICENSED",
  "author": "Jared Goguen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jared-goguen/gutenberg.git"
  },
  "homepage": "https://github.com/jared-goguen/gutenberg#readme",
  "bugs": {
    "url": "https://github.com/jared-goguen/gutenberg/issues"
  },
  "keywords": [
    "gutenberg",
    "cloudflare-pages",
    "mcp",
    "model-context-protocol",
    "semantic-html",
    "page-builder",
    "edit-mode",
    "dynamic-pages",
    "r2-storage"
  ],
  "bin": {
    "gutenberg": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index-lib.d.ts",
      "bun": "./src/index-lib.ts",
      "import": "./dist/src/index-lib.js"
    },
    "./compile": {
      "types": "./dist/src/compile.d.ts",
      "bun": "./src/compile.ts",
      "import": "./dist/src/compile.js"
    },
    "./specs/page": {
      "types": "./dist/src/specs/page/index.d.ts",
      "bun": "./src/specs/page/index.ts",
      "import": "./dist/src/specs/page/index.js"
    },
    "./specs/page/yaml": {
      "types": "./dist/src/specs/page/yaml.d.ts",
      "bun": "./src/specs/page/yaml.ts",
      "import": "./dist/src/specs/page/yaml.js"
    },
    "./specs/page/sanitize": {
      "types": "./dist/src/specs/page/sanitize.d.ts",
      "bun": "./src/specs/page/sanitize.ts",
      "import": "./dist/src/specs/page/sanitize.js"
    },
    "./specs/page/types": {
      "types": "./dist/src/specs/page/types.d.ts",
      "bun": "./src/specs/page/types.ts",
      "import": "./dist/src/specs/page/types.js"
    },
    "./pipeline/editify": {
      "types": "./dist/src/pipeline/editify.d.ts",
      "bun": "./src/pipeline/editify.ts",
      "import": "./dist/src/pipeline/editify.js"
    },
    "./engines/html5": {
      "types": "./dist/src/engines/html5.d.ts",
      "bun": "./src/engines/html5.ts",
      "import": "./dist/src/engines/html5.js"
    },
    "./workers": {
      "types": "./dist/src/workers/index.d.ts",
      "bun": "./src/workers/index.ts",
      "import": "./dist/src/workers/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*.ts",
    "tools/**/*",
    "tsconfig.json"
  ],
  "scripts": {
    "prepare": "tsc --noEmitOnError || true",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build": "tsc --noEmitOnError",
    "build:watch": "tsc --watch --noEmitOnError",
    "build:binary": "bun build --compile --outfile gutenberg ./src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "culori": "^4.0.0",
    "marked": "^18.0.0",
    "puppeteer": "^21.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260423.1",
    "@types/bun": "latest",
    "@types/marked": "^6.0.0",
    "typescript": "^5.0.0"
  }
}